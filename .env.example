# 排單王 (RouteMaster) - 環境變數設定
# 複製此檔案為 .env 並填入您的 API Key

# ==================== Client Side ====================
# Maps SDK API Key (用於 Android 原生 Google Maps 顯示)
GOOGLE_MAPS_ANDROID_API_KEY=你的_ANDROID_GOOGLE_MAPS_API_KEY

# ==================== Server Side ====================
# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=你的_SUPABASE_ANON_KEY

# Google OAuth (原生 SDK 登入用)
# 來源：Google Cloud Console OAuth 2.0 Client (Web client ID)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=你的_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# Google Maps Server API Key
# 用於 Geocoding API、Directions API、Places API
# 這一組是 app runtime 會讀取的 key，因此維持 EXPO_PUBLIC_ 前綴
EXPO_PUBLIC_GOOGLE_MAPS_SERVER_KEY=你的_SERVER_API_KEY

# OpenRouteService API Key
# 用於道路矩陣 (Matrix) 計算
EXPO_PUBLIC_ORS_API_KEY=你的_ORS_API_KEY

# RevenueCat Public SDK Key
# 實際接上購買流程時會使用；目前先保留欄位
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=你的_REVENUECAT_APPLE_PUBLIC_SDK_KEY
EXPO_PUBLIC_REVENUECAT_GOOGLE_API_KEY=你的_REVENUECAT_GOOGLE_PUBLIC_SDK_KEY

# 是否啟用 ORS 道路矩陣最佳化
# true: 優先用 ORS + fallback
# false: 全程使用直線距離
EXPO_PUBLIC_USE_ORS_MATRIX_OPTIMIZATION=true

# 是否使用模擬資料 (開發模式設為 true)
EXPO_PUBLIC_USE_MOCK_DATA=true

# API 端點 (可選，用於自建後端 Proxy)
# EXPO_PUBLIC_API_BASE_URL=https://your-cloud-function-url.cloudfunctions.net

# ==================== Server / Edge Functions ====================
# RevenueCat Webhook 自訂 Bearer Token
REVENUECAT_WEBHOOK_AUTH_HEADER=請填入一段長且隨機的 webhook secret
